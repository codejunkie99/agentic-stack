# env and secrets
.env
.env.local
*.key

# python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# tests live outside the repo — keep in your local working tree but don't
# ship them in releases or the brew bottle.
tests/

# editor
.DS_Store
.idea/
*.swp
.obsidian/

# Claude Code per-user local settings (never committed)
.claude/settings.local.json
.claude/scheduled_tasks.json
.claude/scheduled_tasks.lock

# runtime logs
.agent/memory/dream.log
*.log

# local agent activity/data-layer exports (private, regenerated)
.agent/data-layer/
.agent/data-layer/**

# local approved-run flywheel exports (private, regenerated)
.agent/flywheel/
.agent/flywheel/**

# do NOT ignore memory files — they are the point
!.agent/memory/
!.agent/memory/**

# ...EXCEPT the derived search index (auto-rebuilt, per-machine).
# Placed AFTER the negation above so the later rule wins.
.agent/memory/.index/
.agent/memory/.index/**

# Per-install runtime artifacts — written by tools at runtime, regenerable.
# install_snapshot.json: captured by post_install.take_install_snapshot
# HARNESS_DIFF.md: written by snapshot_diff.py --diff
# HARNESS_FEEDBACK.md: appended by propose_harness_fix.py
# .canonical-citation.json: written by cite_canonical.py (Step 8.4.5 Layer 3)
# .harness-mode.json: written by canonical_gate_prompt.py (Step 8.4.5 Layer 1)
# .session-state.json: written by init_session_state.py (Gap 11 Part B)
# .hook-errors.log: hook fail-open log
.agent/memory/working/install_snapshot.json
.agent/memory/working/HARNESS_DIFF.md
.agent/memory/working/HARNESS_FEEDBACK.md
.agent/memory/working/.canonical-citation.json
.agent/memory/working/.harness-mode.json
.agent/memory/working/.session-state.json
.agent/memory/working/.hook-errors.log

# Client-scoped memory — gitignored to prevent cross-client leakage.
# Each engagement lives in .agent/memory/client/<client-id>/ and never
# leaves the machine. Only _template/ is committed.
# Note: use **-only ignore (not dir/ form) so the negation below works —
# once a directory is ignored with `dir/`, contents under it cannot be
# un-ignored.
.agent/memory/client/**
!.agent/memory/client/_template/
!.agent/memory/client/_template/**
