{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.agent/harness/canonical_gate_prompt.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.agent/harness/canonical_gate_write.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.agent/harness/canonical_gate_stop.py\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python3 .agent/tools/show.py)",
      "Bash(python3 .agent/tools/skill_linter.py)",
      "Bash(python3 .agent/tools/skill_linter.py --staged)",
      "mcp__claude_ai_Microsoft_365__sharepoint_search",
      "mcp__claude_ai_Microsoft_365__sharepoint_folder_search",
      "mcp__claude_ai_Microsoft_365__read_resource",
      "mcp__claude_ai_Microsoft_365__outlook_email_search",
      "mcp__claude_ai_Microsoft_365__chat_message_search"
    ]
  }
}
